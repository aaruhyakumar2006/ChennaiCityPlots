# PostgreSQL connection string (local docker-compose default shown)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prabhadhivya_homes?schema=public"

# Used to sign/verify admin JWTs — generate a long random string for production
JWT_SECRET="replace-with-a-long-random-string"

# Resend (transactional email for lead notifications)
RESEND_API_KEY=""
ADMIN_EMAIL="admin@yourdomain.com"
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# Cloudinary (image upload) — create a free unsigned upload preset in Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Vite-exposed vars for the frontend upload
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET=""

# Google Maps (location advantages, distance calculations)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
