# ── Supabase (required) ────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ── Site URL (required) — used for canonical tags and OG URLs ───────────────
# No trailing slash. Use https://www.madrascityplots.com in production.
VITE_SITE_URL="https://www.madrascityplots.com"

# ── Admin access — comma-separated list of admin email addresses ────────────
VITE_ADMIN_EMAILS="admin@madrascityplots.com"

# ── Groq AI (optional) — powers the NaturalSearchBar AI feature ────────────
# Get a free key at https://console.groq.com
# Without this key the search bar falls back to local keyword parsing.
VITE_GROQ_API_KEY=""

# ── Cloudinary (optional) — property image uploads in the admin panel ──────
# Create a free unsigned upload preset at https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET=""
